# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.

# ============================================================================
# LLM Provider Configuration
# ============================================================================
#
# Choose ONE provider to use. Set LLM_PROVIDER to one of:
#   openai      — OpenAI GPT models (default)
#   openrouter  — Access 100+ models via OpenRouter
#   anthropic   — Anthropic Claude models
#   deepseek    — DeepSeek (cheap, strong reasoning)
#   groq        — Groq (fastest inference for Llama/Mixtral)
#   gemini      — Google Gemini
#   together    — Together AI (open-source models)
#   fireworks   — Fireworks AI (fast open-source inference)
#   ollama      — Local models via Ollama (no API key needed)
#
# Then set the matching API key below, and optionally LLM_MODEL to override
# the default model for that provider.

LLM_PROVIDER=openai
# LLM_MODEL=                  # optional — defaults to a sensible per-provider model

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Default model: gpt-4o-mini  |  Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Default model: openai/gpt-4o-mini  |  Get key: https://openrouter.ai/keys
# Supports 100+ models: anthropic/claude-sonnet-4-5, google/gemini-2.0-flash,
# meta-llama/llama-3.3-70b-instruct, deepseek/deepseek-chat, etc.
# OPENROUTER_API_KEY=sk-or-...

# ─── Anthropic Claude ────────────────────────────────────────────────────────
# Default model: claude-sonnet-4-5  |  Get key: https://console.anthropic.com/
# Other models: claude-opus-4-6, claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# ─── DeepSeek ────────────────────────────────────────────────────────────────
# Default model: deepseek-chat  |  Get key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...

# ─── Groq (fast Llama/Mixtral inference) ────────────────────────────────────
# Default model: llama-3.3-70b-versatile  |  Get key: https://console.groq.com/
# GROQ_API_KEY=gsk_...

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Default model: gemini-2.0-flash  |  Get key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...

# ─── Together AI ─────────────────────────────────────────────────────────────
# Default model: meta-llama/Llama-3.3-70B-Instruct-Turbo
# Get key: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=...

# ─── Fireworks AI ────────────────────────────────────────────────────────────
# Default model: accounts/fireworks/models/llama-v3p3-70b-instruct
# Get key: https://fireworks.ai/api-keys
# FIREWORKS_API_KEY=fw_...

# ─── Ollama (local, no API key needed) ──────────────────────────────────────
# Default model: llama3.2  |  Install: https://ollama.com/
# Run `ollama serve` and `ollama pull llama3.2` before starting the backend.
# OLLAMA_BASE_URL=http://localhost:11434/v1
